# Supabase (project API settings)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel AI Gateway / app (existing)
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=

# Optional: base URL for Gateway Usage & Reporting APIs (`/v1/credits`, `/v1/report`).
# Defaults to https://ai-gateway.vercel.sh/v1 (not the AI SDK `/v1/ai` base).
# AI_GATEWAY_USAGE_API_ROOT=https://ai-gateway.vercel.sh/v1

# MCP — local stdio (default): optional path to built server entry (see getMcpServerPath()).
# MCP_SERVER_PATH=

# MCP — remote (Streamable HTTP; recommended for serverless / Cloudflare Workers).
# Same SDK as local: @modelcontextprotocol/sdk StreamableHTTPClientTransport (POST + SSE).
# MCP_SERVER_URL=https://your-worker.workers.dev/mcp
# Alias:
# MCP_REMOTE_URL=
# Legacy SSE-only servers: MCP_TRANSPORT=sse
# Auth (optional): Bearer token or extra headers JSON object string.
# MCP_SERVER_BEARER_TOKEN=
# MCP_SERVER_HEADERS_JSON={"X-Api-Key":"..."}

# Cloudflare Turnstile (login)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Signed httpOnly cookie for “CAPTCHA solved” proof (login retries). Required in production.
CAPTCHA_COOKIE_SECRET=

# Optional: chat quota (defaults: 15 per rolling 24h)
# CHAT_QUOTA_MAX=15
# CHAT_QUOTA_WINDOW_HOURS=24

# Quota extension (playground / demo): when set, authenticated users at 0 remaining can POST
# /api/chat/quota/extend with this passphrase to reduce their usage count (grants more sends).
# Use a strong value in production; omit entirely to hide the feature from the UI.
# CHAT_QUOTA_EXTENSION_SECRET=admin
# CHAT_QUOTA_EXTENSION_CREDITS=5

# Prompt editor gate (existing)
# ALLOW_PROMPT_EDITOR=false

# --- Observability (hybrid: Vercel AI Gateway dashboard + LangSmith traces) ---
# Gateway usage, latency, and spend: Vercel dashboard → AI Gateway → Observability.
# App-level traces (POST /api/chat, tool steps): LangSmith
# OBSERVABILITY_PROVIDER=langsmith
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# Optional LangChain-prefixed aliases (also supported by the SDK):
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGSMITH_PROJECT=ib-ai-incident-assistant
# Self-hosted LangSmith:
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
#
# Dataset name for portfolio eval scripts (optional; defaults to ib-ai-incident-playground)
# LANGSMITH_INCIDENT_DATASET=ib-ai-incident-playground
